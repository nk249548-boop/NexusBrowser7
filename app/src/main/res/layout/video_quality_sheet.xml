<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tvSheetTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Video Quality"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- FIX: tvCurrentQuality add kiya — BottomSheet code isko use karta hai -->
        <TextView
            android:id="@+id/tvCurrentQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Current: Auto"
            android:textColor="#666666"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp" />

    <!-- RecyclerView for Quality Options -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResolutions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:layout_marginBottom="16dp" />

    <!-- Info Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvQualityInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Higher quality uses more data"
            android:textColor="#666666"
            android:textSize="12sp" />

    </LinearLayout>

</LinearLayout>
