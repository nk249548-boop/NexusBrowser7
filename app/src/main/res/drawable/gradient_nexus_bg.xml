<?xml version="1.0" encoding="utf-8"?>
<!--
    NexusBrowser Gradient Background (alternate)
    Matches photo: teal base + blue + orange/yellow + coral/red blobs
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base: soft mint-teal background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#CCE8E0" />
        </shape>
    </item>

    <!-- Top-right blue-teal blob -->
    <item
        android:left="100dp"
        android:top="-100dp"
        android:right="-100dp"
        android:bottom="250dp">
        <shape android:shape="oval">
            <solid android:color="#60B0D0E8" />
        </shape>
    </item>

    <!-- Center-right blue blob -->
    <item
        android:left="120dp"
        android:top="80dp"
        android:right="-80dp"
        android:bottom="260dp">
        <shape android:shape="oval">
            <solid android:color="#5090B8DE" />
        </shape>
    </item>

    <!-- Bottom-left warm orange-yellow blob -->
    <item
        android:left="-60dp"
        android:top="360dp"
        android:right="140dp"
        android:bottom="-80dp">
        <shape android:shape="oval">
            <solid android:color="#80ECC060" />
        </shape>
    </item>

    <!-- Bottom-center red-orange blob -->
    <item
        android:left="50dp"
        android:top="420dp"
        android:right="50dp"
        android:bottom="-100dp">
        <shape android:shape="oval">
            <solid android:color="#68E08070" />
        </shape>
    </item>

    <!-- Top white fade overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#22FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
